.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f5f5f5;
}

.header {
  flex-shrink: 0;
  padding: 20rpx;
}

.route-title {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
  padding: 24rpx 30rpx;
  border-radius: 16rpx;
  gap: 16rpx;
}

.city {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}

.arrow-icon {
  font-size: 32rpx;
  color: #1AAD19;
}

.date-text {
  font-size: 24rpx;
  color: #999;
  margin-left: 16rpx;
}

.loading {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}

.content-scroll {
  flex: 1;
  overflow: hidden;
  padding: 0 20rpx;
}

.direct-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 30rpx;
  margin-bottom: 20rpx;
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.direct-tag {
  font-size: 22rpx;
  color: #1AAD19;
  background: #e8f8e8;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.price-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.price-label {
  font-size: 26rpx;
  color: #666;
}

.price-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #ff6600;
}

.info-row {
  display: flex;
  gap: 30rpx;
}

.info-item {
  font-size: 24rpx;
  color: #999;
}

.section {
  margin-bottom: 20rpx;
}

.section-title {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
  padding-left: 8rpx;
}

.title-icon {
  font-size: 32rpx;
}

.transfer-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 30rpx;
  margin-bottom: 16rpx;
  border-left: 6rpx solid #1AAD19;
}

.transfer-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.transit-city {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.save-tag {
  font-size: 22rpx;
  color: #fff;
  background: #ff6600;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.reach-tag {
  font-size: 22rpx;
  color: #1AAD19;
  background: #e8f8e8;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.transfer-body {
  background: #f9f9f9;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
}

.leg {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.leg-route {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 28rpx;
  color: #333;
}

.leg-highlight {
  color: #1AAD19;
  font-weight: bold;
}

.leg-arrow {
  color: #ccc;
}

.leg-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.leg-price {
  font-size: 28rpx;
  font-weight: bold;
  color: #ff6600;
}

.leg-detail {
  font-size: 22rpx;
  color: #999;
}

.leg-divider {
  text-align: center;
  font-size: 22rpx;
  color: #ccc;
  padding: 10rpx 0;
}

.transfer-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.total-price {
  font-size: 32rpx;
  font-weight: bold;
  color: #ff6600;
}

.total-duration {
  font-size: 24rpx;
  color: #999;
}

.toggle-btn {
  text-align: center;
  padding: 20rpx;
  color: #1AAD19;
  font-size: 26rpx;
}

.other-list {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.other-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.other-item:last-child {
  border-bottom: none;
}

.other-city {
  font-size: 28rpx;
  color: #333;
  flex: 1;
}

.other-price {
  font-size: 28rpx;
  font-weight: bold;
  color: #ff6600;
  margin-right: 20rpx;
}

.other-duration {
  font-size: 24rpx;
  color: #999;
}

.no-recommend,
.no-result {
  text-align: center;
  padding: 60rpx 0;
  color: #999;
  font-size: 28rpx;
}

.bottom-space {
  height: 120rpx;
}

.refresh-btn {
  position: fixed;
  bottom: 40rpx;
  left: 50%;
  transform: translateX(-50%);
  background: #1AAD19;
  color: #fff;
  padding: 20rpx 60rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  text-align: center;
  z-index: 10;
}
