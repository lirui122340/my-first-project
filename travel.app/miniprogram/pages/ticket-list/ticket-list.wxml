<view class="container">
  <view class="route-bar">
    <text class="route-from">{{fromStation || fromCity}}</text>
    <text class="route-arrow">→</text>
    <text class="route-to">{{toStation || toCity}}</text>
    <text class="route-date">{{date}}</text>
  </view>

  <view class="filter-bar">
    <text
      class="filter-item {{trainType === 'all' ? 'active' : ''}}"
      data-type="all"
      bindtap="onTrainTypeChange"
    >全部</text>
    <text
      class="filter-item {{trainType === 'G-D' ? 'active' : ''}}"
      data-type="G-D"
      bindtap="onTrainTypeChange"
    >高铁/动车</text>
    <text
      class="filter-item {{trainType === 'K-T-Z' ? 'active' : ''}}"
      data-type="K-T-Z"
      bindtap="onTrainTypeChange"
    >普通</text>
    <text class="filter-item route-btn" bindtap="onRouteRecommend">💡省钱路线</text>
  </view>

  <view wx:if="{{loading}}" class="loading">
    <text>正在查询12306实时票价...</text>
  </view>

  <view wx:elif="{{tickets.length === 0}}" class="empty">
    <text>暂无车次信息</text>
  </view>

  <view wx:else class="ticket-list">
    <view wx:for="{{tickets}}" wx:key="trainNo" class="ticket-card">
      <view class="ticket-header">
        <text class="train-no">{{item.trainNo}}</text>
        <text class="duration">{{item.duration}}</text>
      </view>

      <view class="ticket-time">
        <view class="time-block">
          <text class="time">{{item.startTime}}</text>
          <text class="station">{{item.fromStation}}</text>
        </view>
        <view class="time-arrow">→</view>
        <view class="time-block">
          <text class="time">{{item.arriveTime}}</text>
          <text class="station">{{item.toStation}}</text>
        </view>
      </view>

      <view class="ticket-seats">
        <view wx:for="{{item.seatList}}" wx:for-item="seat" wx:key="type" class="seat-row">
          <text class="seat-type">{{seat.type}}</text>
          <text class="seat-count {{seat.count === '无' || seat.count === 0 ? 'sold-out' : 'available'}}">{{seat.count}}</text>
          <text wx:if="{{seat.price > 0}}" class="seat-price">¥{{seat.price}}</text>
        </view>
      </view>
    </view>
  </view>
</view>
