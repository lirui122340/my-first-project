.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f5f5f5;
}

.header {
  flex-shrink: 0;
  padding: 20rpx 20rpx 0;
}

.city-info {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #fff;
  padding: 24rpx 30rpx;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
}

.city-name {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}

.avg-price {
  font-size: 26rpx;
  color: #ff6600;
}

.filter-bar {
  display: flex;
  background: #fff;
  padding: 12rpx 20rpx;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  gap: 12rpx;
}

.filter-item {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
  color: #999;
  padding: 10rpx 0;
  border-radius: 30rpx;
  background: #f5f5f5;
}

.filter-item.active {
  background: #1AAD19;
  color: #fff;
}

.loading {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}

.content-scroll {
  flex: 1;
  overflow: hidden;
  padding: 0 20rpx;
}

.empty {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}

.hostel-cards {
  padding-bottom: 20rpx;
}

.hostel-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 30rpx;
  margin-bottom: 16rpx;
}

.hostel-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.hostel-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 1;
}

.hostel-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.hostel-type {
  font-size: 20rpx;
  padding: 2rpx 12rpx;
  border-radius: 16rpx;
}

.type-hostel {
  color: #1AAD19;
  background: #e8f8e8;
}

.type-hotel {
  color: #1890ff;
  background: #e6f7ff;
}

.hostel-rating {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.rating-star {
  font-size: 24rpx;
  color: #ffc107;
}

.rating-num {
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
}

.hostel-mid {
  margin-bottom: 12rpx;
}

.hostel-location {
  font-size: 24rpx;
  color: #666;
}

.hostel-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 16rpx;
}

.tag {
  font-size: 20rpx;
  color: #999;
  background: #f5f5f5;
  padding: 4rpx 14rpx;
  border-radius: 16rpx;
}

.hostel-bottom {
  display: flex;
  align-items: baseline;
}

.hostel-price {
  font-size: 36rpx;
  font-weight: bold;
  color: #ff6600;
}

.price-unit {
  font-size: 22rpx;
  color: #999;
  margin-left: 4rpx;
}

.bottom-space {
  height: 120rpx;
}

.refresh-btn {
  position: fixed;
  bottom: 40rpx;
  left: 50%;
  transform: translateX(-50%);
  background: #1AAD19;
  color: #fff;
  padding: 20rpx 60rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  text-align: center;
  z-index: 10;
}
