<view class="page">
  <view class="header">
    <view class="info-bar">
      <text class="info-text">{{fromCity}}出发 · {{date}}</text>
    </view>
  </view>

  <view wx:if="{{loading}}" class="loading">
    <text>加载中...</text>
  </view>

  <view wx:elif="{{destinations.length === 0}}" class="empty">
    <text>暂无可直达城市</text>
  </view>

  <scroll-view
    wx:else
    scroll-y
    class="city-scroll"
    enhanced
    show-scrollbar="{{false}}"
  >
    <view class="city-cards">
      <view
        wx:for="{{destinations}}"
        wx:key="*this"
        class="city-card"
        data-city="{{item}}"
        bindtap="onCityTap"
      >
        <view class="city-name">{{item}}</view>
        <view class="city-actions">
          <text class="action-hostel" catchtap="onHostelTap" data-city="{{item}}">🏨住宿</text>
          <text class="arrow">查看车次 ></text>
        </view>
      </view>
    </view>
    <view class="bottom-space"></view>
  </scroll-view>

  <view class="refresh-btn" bindtap="onRefresh">刷新</view>
</view>
