.city-picker {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: #f5f5f5;
  z-index: 999;
}

.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx;
  background: #fff;
}

.picker-title {
  font-size: 32rpx;
  font-weight: bold;
}

.cancel-btn {
  font-size: 28rpx;
  color: #1AAD19;
}

.placeholder {
  width: 60rpx;
}

.search-bar {
  padding: 20rpx 30rpx;
  background: #fff;
}

.search-input {
  background: #f5f5f5;
  border-radius: 30rpx;
  padding: 16rpx 30rpx;
  font-size: 28rpx;
}

.city-list {
  height: calc(100vh - 200rpx);
}

.section {
  background: #fff;
  margin-bottom: 20rpx;
}

.section-title {
  display: block;
  padding: 20rpx 30rpx;
  font-size: 26rpx;
  color: #999;
  background: #f5f5f5;
}

.hot-cities {
  display: flex;
  flex-wrap: wrap;
  padding: 20rpx 30rpx;
}

.hot-city-item {
  width: 160rpx;
  height: 64rpx;
  line-height: 64rpx;
  text-align: center;
  margin: 10rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 26rpx;
}

.city-item {
  padding: 24rpx 30rpx;
  font-size: 28rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.empty {
  text-align: center;
  padding: 60rpx;
  color: #999;
  font-size: 28rpx;
}

.letter-bar {
  position: fixed;
  right: 10rpx;
  top: 50%;
  transform: translateY(-50%);
  display: flex;
  flex-direction: column;
  z-index: 1000;
}

.letter-item {
  font-size: 22rpx;
  color: #1AAD19;
  padding: 4rpx 10rpx;
}
